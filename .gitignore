# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.next-runtime*/
/.next-preview*/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo

# private workspace artifacts (Codex / Claude / Cursor / etc.)
.Codex/
.codex/
.claude/
.cursor/
.aider*

# launch video workspace (Remotion) - local only, never pushed
/video/

# private project notes — not shipped publicly
/project-context/
/creed.md
/design.md
/docs.md

# legacy / accidental git working trees
.git.backup-*

# Supabase CLI temp state (contains the linked project ref + org)
supabase/.temp/

# OS / editor cruft
*.log
.idea/
.vscode/
